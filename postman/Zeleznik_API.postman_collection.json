    {
      "name": "CREATE Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const unique = Date.now();",
              "pm.collectionVariables.set('testUsername', `janez_${unique}`);",
              "pm.collectionVariables.set('testEmail', `janez_${unique}@test.com`);",
              "pm.collectionVariables.set('testPassword', 'geslo123');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status je 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Registracija vrne user podatke', function () {",
              "  pm.expect(json.user).to.be.an('object');",
              "  pm.expect(json.user.email).to.eql(pm.collectionVariables.get('testEmail'));",
              "  pm.expect(json.user.username).to.eql(pm.collectionVariables.get('testUsername'));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{testUsername}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/API/CREATE/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "API",
            "CREATE",
            "register"
          ]
        }
      }
