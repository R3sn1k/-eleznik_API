  "item": [
    {
      "name": "GET Overview",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status je 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Vrne GET/CREATE/UPDATE/DELETE strukturo', function () {",
              "  pm.expect(json.projectStructure).to.be.an('object');",
              "  pm.expect(json.projectStructure.GET).to.eql('/API/GET');",
              "  pm.expect(json.projectStructure.CREATE).to.eql('/API/CREATE');",
              "  pm.expect(json.projectStructure.UPDATE).to.eql('/API/UPDATE');",
              "  pm.expect(json.projectStructure.DELETE).to.eql('/API/DELETE');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      }
    },
