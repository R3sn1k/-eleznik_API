    {
      "name": "CREATE Weather",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status je 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Create weather vrne nov zapis', function () {",
              "  pm.expect(json.data).to.be.an('object');",
              "  pm.expect(json.data.city).to.eql('Ptuj');",
              "});",
              "if (json.data && json.data.id) {",
              "  pm.collectionVariables.set('createdWeatherId', json.data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
